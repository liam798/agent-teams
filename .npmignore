# 源代码（只发布编译后的 dist）
src/
*.ts
!*.d.ts

# 测试文件（源代码和编译后的）
*.test.ts
*.spec.ts
**/*.test.ts
**/*.spec.ts
**/*.test.js
**/*.spec.js
**/*.test.d.ts
**/*.spec.d.ts
test/
tests/
__tests__/
coverage/
.vitest/
dist/**/*.test.js
dist/**/*.spec.js
dist/**/*.test.d.ts
dist/**/*.spec.d.ts

# 开发工具
.vscode/
.idea/
*.swp
*.swo
*~

# 构建工具
tsconfig.json
vitest.config.ts

# 文档（README.md 会包含，其他文档不发布）
docs/
ARCHITECTURE.md
DESIGN_REVIEW.md
IMPROVEMENTS.md
TESTING.md
CODEX_USAGE.md
QUICK_START.md
RELEASE.md
PUBLISH.md

# Git
.git/
.gitignore
.gitattributes

# 其他
.DS_Store
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# 环境变量
.env
.env.local
.env.*.local

# 临时文件
tmp/
temp/
*.tmp
